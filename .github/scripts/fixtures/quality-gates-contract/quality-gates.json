{
  "schema_version": 1,
  "implementation_profile": "final",
  "policy": {
    "baseline_policy": "explicit-waiver-required",
    "require_signed_commits": true,
    "branch_protection": {
      "protected_branches": [
        "main"
      ],
      "require_pull_request": true,
      "disallow_direct_pushes": true,
      "disallow_branch_deletions": true,
      "disallow_force_pushes": true,
      "allow_merge_commits": true,
      "require_merge_queue": false,
      "required_reviewers": [],
      "required_status_checks": {
        "strict": true,
        "integrations": {
          "Release intent label gate": 15368,
          "Lint & Checks": 15368,
          "Backend Tests": 15368,
          "Frontend E2E": 15368,
          "Worktree Bootstrap Smoke (ubuntu-latest)": 15368,
          "Worktree Bootstrap Smoke (macos-latest)": 15368,
          "Build (Release)": 15368,
          "Review Policy Gate": 15368
        }
      }
    },
    "review_policy": {
      "mode": "conditional-required",
      "required_approvals": 1,
      "exempt_repository_owner": true,
      "exempt_author_permissions": [
        "admin",
        "maintain"
      ],
      "allowed_reviewer_permissions": [
        "write",
        "maintain",
        "admin"
      ],
      "enforcement": {
        "mode": "required-check",
        "check_name": "Review Policy Gate"
      }
    }
  },
  "required_checks": [
    "Release intent label gate",
    "Lint & Checks",
    "Backend Tests",
    "Frontend E2E",
    "Worktree Bootstrap Smoke (ubuntu-latest)",
    "Worktree Bootstrap Smoke (macos-latest)",
    "Build (Release)",
    "Review Policy Gate"
  ],
  "informational_checks": [],
  "waivers": [],
  "expected_pr_workflows": [
    {
      "workflow": "PR Label Gate",
      "jobs": [
        "Release intent label gate"
      ]
    },
    {
      "workflow": "CI Pipeline",
      "jobs": [
        "Lint & Checks",
        "Backend Tests",
        "Frontend E2E",
        "Worktree Bootstrap Smoke (ubuntu-latest)",
        "Worktree Bootstrap Smoke (macos-latest)",
        "Build (Release)"
      ]
    },
    {
      "workflow": "Review Policy",
      "jobs": [
        "Review Policy Gate"
      ]
    }
  ]
}
